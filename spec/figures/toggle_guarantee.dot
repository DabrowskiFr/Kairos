digraph G {
  rankdir=LR;
  node [shape=circle];
  q0 [shape=doublecircle,label="q0"];
  q1 [shape=doublecircle,label="q1"];
  bad_G [shape=circle,label="bad_G"];
  q0 -> q1 [label="y=0"];
  q0 -> bad_G [label="y!=0"];
  q1 -> q0 [label="y=1"];
  q1 -> bad_G [label="y!=1"];
  bad_G -> bad_G [label="true"];
}
