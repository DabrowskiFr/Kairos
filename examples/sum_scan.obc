node sum_scan(x: int) returns (y: int)
assume G( {x} >= {0} );
guarantee G( X( {y} = fold(add, {0}, {x}) ) );
invariants
  invariant acc = fold(add, {0}, {x});
locals
  acc : int;
  init_done : bool;
states
  S;
init S
trans
  S -> S {
    if not init_done then
      acc := 0;
      init_done := true;
    else
      acc := acc + x;
    end;
    y := acc;
  }
end
