node first_value(x: int) returns (y: int)
guarantee G( {y} = fold(first, {x}, {x}) );
invariants
  invariant first_val = fold(first, {x}, {x});
locals
  first_val : int;
states
  Init, Run;
init Init
trans
  Init -> Run {
    ensures {first_val} = {x};
    ensures {y} = {first_val};
    ensures {y} = {x};
    first_val := x;
    y := x;
  }
  Run -> Run {
    ensures {y} = {first_val};
    ensures {first_val} = pre(first_val);
    y := first_val;
  }
end
