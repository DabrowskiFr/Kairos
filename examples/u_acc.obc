node u_acc(x: int) returns (y: int)
requires {x} >= {1};
guarantee G( {y} <= {acc} );
guarantee G( ({y} < {10}) U ({y} >= {10}) );
locals
  acc : int;
  init_done : bool;
states
  S;
init S
trans
  S -> S {
    if not init_done then
      acc := x;
      init_done := true;
    else
      acc := acc + x;
    end;
    y := acc;
  }
end
