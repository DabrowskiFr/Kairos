node toggle01() returns (y: int)
guarantee G( {y} = {0} => X( {y} = {1} ) );
invariants
  invariant y = {1 - prev};
locals
  prev : int;
states
  Init, Run;
init Init
trans
  Init -> Run {
    ensures {prev} = {1};
    ensures {y} = {0};
    prev := 1;
    y := 0;
  }
  Run -> Run {
    ensures {y} = {1 - prev};
    prev := y;
    y := 1 - prev;
  }
end
