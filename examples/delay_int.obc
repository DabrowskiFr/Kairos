node delay_int(x: int) returns (y: int)
guarantee G( {y} = pre(x, 0) );
invariants
  invariant state = Init -> pre(x, 0) = {0};
  invariant state = Run -> {prev} = pre(x, 0);
locals
  prev: int;
states
  Init, Run;
init Init
trans
  Init -> Run {
    requires pre(x, 0) = {0};
    ensures {y} = {0};
    y := 0;
    prev := x;
  }
  Run -> Run {
    requires {prev} = pre(x, 0);
    ensures {y} = pre(prev);
    y := prev;
    prev := x;
  }
end
