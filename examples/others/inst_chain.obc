node inc(x: int) returns (y: int)
guarantee G( X( {y} = {x + 1} ) );
locals
  (* none *)
states
  S;
init S
trans
  S -> S {
    y := x + 1;
  }
end

node chain2(x: int) returns (y: int)
instances
  instance a1: inc;
  instance a2: inc;
locals
  t: int;
states
  S;
init S
trans
  S -> S {
    call a1(x) returns (t);
    call a2(t) returns (y);
  }
end
