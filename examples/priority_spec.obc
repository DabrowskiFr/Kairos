node priority_spec(x: int) returns (y: int)
guarantee G( {y} = {s} );
guarantee G( ({x} < {10}) or F( {y} = {2} ) );
guarantee G( ({x} >= {10}) or X( {y} = {1} ) );
locals
  s : int;
states
  S0, S1, S2;
init S0
trans
  S0 -> S1 [x >= 0] {
    y := 1;
    s := 1;
  }
  S0 -> S2 [x >= 10] {
    y := 2;
    s := 2;
  }
  S1 -> S1 {
    y := 1;
    s := 1;
  }
  S2 -> S2 {
    y := 2;
    s := 2;
  }
end
