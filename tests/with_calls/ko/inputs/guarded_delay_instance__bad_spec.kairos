import "./guarded_delay_core.kobj";

node guarded_delay_instance(enable: int, x: int) returns (y: int)
contracts
  ensures: G (undefined_spec_symbol = 0);
instances
  instance d: guarded_delay_core;
states
  Init(init), Idle, Run;
transitions
  Init:
    to Run when enable = 1 {
      call d(x) returns (y);
    }
    to Idle when enable = 0 {
      y := 0;
    }
  Idle:
    to Run when enable = 1 {
      call d(x) returns (y);
    }
    to Idle when enable = 0 {
      y := 0;
    }
  Run:
    to Run {
      call d(x) returns (y);
    }
end
