(* BAD CODE — should be rejected by the verifier.
   Difference from ok/gated_echo_bundle.kairos:
     Hold -> Hold sets  y := 0  and  z := 0  instead of  y := hold  and  z := hold.
   Why it must be rejected:
     The Hold-state invariant requires  y = hold and z = y.  Setting both to 0
     in the self-loop violates both invariant clauses.
     The contracts capturing sample-then-hold bundle behavior are broken because
     y and z are 0 instead of echoing the latched value. *)
node gated_echo_bundle(gate: int, x: int) returns (y: int, z: int)
contracts
  ensures: G (gate = 1 => X ((y = prev x) and (z = y)));
  ensures: G (gate = 1 => X G ((y = prev y) and (z = y)));
locals
  hold: int;
states
  Init(init), Wait, Hold;
invariants
  in Hold:
    y = hold and
    y = prev y and
    z = y and
    hold = prev y;
    prev gate = 1 => y = prev x;
transitions
  Init:
    to Hold when gate = 1 {
      y := x;
      z := x;
      hold := x;
    }
    to Wait when gate = 0 {
      y := 0;
      z := 0;
      hold := x;
    }
  Wait:
    to Hold when gate = 1 {
      y := x;
      z := x;
      hold := x;
    }
    to Wait when gate = 0 {
      y := 0;
      z := 0;
      hold := x;
    }
  Hold:
    to Hold {
      y := 0; // BUG: should be  y := hold
      z := 0; // BUG: should be  z := hold  (Hold invariant: y = hold and z = y)
      hold := hold;
    }
end
