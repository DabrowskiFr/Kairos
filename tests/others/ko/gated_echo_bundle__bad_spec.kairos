node gated_echo_bundle(gate: int, x: int) returns (y: int, z: int)
contracts
  ensures: G (gate = 1 => X G ((y = x) and (z = y)));
locals
  hold: int;
states
  Init(init), Wait, Hold;
invariants
  in Hold:
    y = hold and
    y = prev y and
    z = y and
    hold = prev y;
    prev gate = 1 => y = prev x;
transitions
  Init:
    to Hold when gate = 1 {
      y := x;
      z := x;
      hold := x;
    }
    to Wait when gate = 0 {
      y := 0;
      z := 0;
      hold := x;
    }
  Wait:
    to Hold when gate = 1 {
      y := x;
      z := x;
      hold := x;
    }
    to Wait when gate = 0 {
      y := 0;
      z := 0;
      hold := x;
    }
  Hold:
    to Hold {
      y := hold;
      z := hold;
      hold := hold;
    }
end
