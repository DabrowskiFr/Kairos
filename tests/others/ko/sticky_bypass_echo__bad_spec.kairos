node sticky_bypass_echo(bypass: int, x: int) returns (y: int)
contracts
  ensures: G (bypass = 1 => X G (y = x));
locals
  latched: int;
states
  Init(init), Wait, Hold;
invariants
  in Hold:
    y = latched;
    y = prev y;
    latched = prev y;
    prev bypass = 1 => y = prev x;
transitions
  Init:
    to Hold when bypass = 1 {
      y := x;
      latched := x;
    }
    to Wait when bypass = 0 {
      y := 0;
      latched := x;
    }
  Wait:
    to Hold when bypass = 1 {
      y := x;
      latched := x;
    }
    to Wait when bypass = 0 {
      y := 0;
      latched := x;
    }
  Hold:
    to Hold {
      y := latched;
      latched := latched;
    }
end
