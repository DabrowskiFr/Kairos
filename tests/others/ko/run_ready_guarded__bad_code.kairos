(* BAD CODE — should be rejected by the verifier.
   Differences from ok/run_ready_guarded.kairos:
     Idle -> Run and Run -> Run both set  mode := 0  instead of  mode := 1.
     Idle -> Run and Run -> Run both set  ready := 0  regardless of err,
       instead of setting  ready := (if err=0 then 1 else 0).
   Why it must be rejected:
     The Run-state invariant requires  mode = armed = 1.  Setting mode := 0
     violates this immediately upon entering / staying in Run.
     The contracts  G(go=1 => G(mode=1))  and  G(mode=1 => G((err=0) => ready=1))
     are both broken: mode is never 1 after Init, and ready is always 0
     even when err = 0. *)
node run_ready_guarded(go: int, err: int) returns (mode: int, ready: int)
contracts
  requires: G (err = 0 or err = 1);
  ensures: G (go = 1 => G (mode = 1));
  ensures: G (mode = 1 => G ((err = 0) => (ready = 1)));
  ensures: G (mode = 1 => G ((err = 1) => (ready = 0)));
locals
  armed: int;
states
  Init(init), Idle, Run;
invariants
  in Idle:
    mode = 0 and
    armed = 0;
  in Run:
    mode = armed and
    armed = 1;
transitions
  Init:
    to Run when go = 1 {
      armed := 1;
      mode := 1;
      if err = 0 then ready := 1;
      else ready := 0; end;
    }
    to Idle when go = 0 {
      armed := 0;
      mode := 0;
      ready := 0;
    }
  Idle:
    to Run when go = 1 {
      armed := 1;
      mode := 0; // BUG: should be  mode := 1  (violates Run invariant  mode = armed = 1)
      if err = 0 then ready := 0; // BUG: should be  ready := 1  when err = 0
      else ready := 0; end;
    }
    to Idle when go = 0 {
      armed := 0;
      mode := 0;
      ready := 0;
    }
  Run:
    to Run {
      armed := 1;
      mode := 0; // BUG: should be  mode := 1  (violates Run invariant  mode = armed = 1)
      if err = 0 then ready := 0; // BUG: should be  ready := 1  when err = 0
      else ready := 0; end;
    }
end
