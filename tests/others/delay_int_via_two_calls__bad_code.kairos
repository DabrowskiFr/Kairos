(* BAD CODE — should be rejected by the verifier.
   Difference from others/delay_int_via_two_calls.kairos:
     Init -> Run overwrites the second-instance result with  y := 0  after the call.
   Why it must be rejected:
     Instances d1 then d2 implement a two-cycle delay.  Setting y := 0 in Init -> Run
     discards the composed result during the initialisation step.
     The contract  next next always(y = prev2 x)  cannot hold because the delay
     chain is broken at initialisation. *)
import "./delay_int.kobj";

node delay_int_via_two_calls(x: int) returns (y: int)
contracts
  ensures: next next always (y = prev2 x);
instances
  instance d1: delay_int;
  instance d2: delay_int;
locals
  t : int;
states
  Init(init), Run;
transitions
  Init:
    to Run {
      call d1(x) returns (t);
      call d2(t) returns (y);
      y := 0; // BUG: overwrites instance result — should be removed
    }
  Run:
    to Run {
      call d1(x) returns (t);
      call d2(t) returns (y);
    }
end
