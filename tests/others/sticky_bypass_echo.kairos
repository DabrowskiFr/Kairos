node sticky_bypass_echo(bypass: int, x: int) returns (y: int)
contracts
  ensures: G ((bypass = 1 and not prev bypass = 1) => X (y = prev x));
  ensures: G ((bypass = 1 and not prev bypass = 1) => X G (y = prev y));
locals
  latched: int;
states
  Init(init), Wait, Fresh, Hold;
invariants
  in Fresh:
    y = latched;
  in Hold:
    y = latched and
    y = prev y;
transitions
  Init:
    to Fresh when bypass = 1 {
      y := x;
      latched := x;
    }
    to Wait when bypass = 0 {
      y := 0;
      latched := x;
    }
  Wait:
    to Fresh when bypass = 1 {
      y := x;
      latched := x;
    }
    to Wait when bypass = 0 {
      y := 0;
      latched := x;
    }
  Fresh:
    to Hold {
      y := latched;
      latched := latched;
    }
  Hold:
    to Hold {
      y := latched;
      latched := latched;
    }
end
