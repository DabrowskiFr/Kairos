node armed_one_forever(x: int) returns (y: int)
contracts
  requires: G (x = 0 or x = 1);
  ensures: G (x = 1 => G (y = 1));
states
  Init(init), Armed;
invariants
  in Armed:
    y = 1;
transitions
  Init:
    to Init when x = 0 {
      skip;
    }
    to Armed when x = 1 {
      y := 1;
    }
  Armed:
    to Armed {
      skip;
    }
end
