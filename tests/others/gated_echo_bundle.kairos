node gated_echo_bundle(gate: int, x: int) returns (y: int, z: int)
contracts
  ensures: G ((gate = 1 and not prev gate = 1) => X ((y = prev x) and (z = y)));
  ensures: G ((gate = 1 and not prev gate = 1) => X G ((y = prev y) and (z = y)));
locals
  hold: int;
states
  Init(init), Wait, Fresh, Hold;
invariants
  in Fresh:
    y = hold and
    z = y;
  in Hold:
    y = hold and
    z = y and
    y = prev y;
transitions
  Init:
    to Fresh when gate = 1 {
      y := x;
      z := x;
      hold := x;
    }
    to Wait when gate = 0 {
      y := 0;
      z := 0;
      hold := x;
    }
  Wait:
    to Fresh when gate = 1 {
      y := x;
      z := x;
      hold := x;
    }
    to Wait when gate = 0 {
      y := 0;
      z := 0;
      hold := x;
    }
  Fresh:
    to Hold {
      y := hold;
      z := hold;
      hold := hold;
    }
  Hold:
    to Hold {
      y := hold;
      z := hold;
      hold := hold;
    }
end
