(* BAD CODE — should be rejected by the verifier.
   Differences from others/pair_pipeline_guarded.kairos:
     Idle -> Run and Run -> Run both set  a := 0  and  b := 0  after the
     call to d, discarding the result, instead of  a := midv  and  b := midv.
   Why it must be rejected:
     The instance d returns the pipeline-delayed value in midv.  Overwriting
     a and b with 0 discards this result.
     The contract  G(enable=1 => X G((a = prev x) and (b = a)))  is broken
     because a and b are always 0 instead of reflecting the pipeline output. *)
import "./pair_pipeline_core.kobj";

node pair_pipeline_guarded(enable: int, x: int) returns (a: int, b: int)
contracts
  ensures: G (enable = 1 => X G ((a = prev x) and (b = a)));
instances
  instance d: pair_pipeline_core;
locals
  midv: int;
states
  Init(init), Idle, Run;
transitions
  Init:
    to Run when enable = 1 {
      call d(x) returns (midv);
      a := midv;
      b := midv;
    }
    to Idle when enable = 0 {
      a := 0;
      b := 0;
    }
  Idle:
    to Run when enable = 1 {
      call d(x) returns (midv);
      a := 0; // BUG: should be  a := midv
      b := 0; // BUG: should be  b := midv  (discards instance result)
    }
    to Idle when enable = 0 {
      a := 0;
      b := 0;
    }
  Run:
    to Run {
      call d(x) returns (midv);
      a := 0; // BUG: should be  a := midv
      b := 0; // BUG: should be  b := midv  (discards instance result)
    }
end
