(rule
 (alias runtest)
 (targets toggle_toggle.why)
 (deps toggle/toggle.obc)
 (action
  (progn
   (with-stdout-to toggle_toggle.why
    (run %{bin:obc2why3} toggle/toggle.obc))
   (run %{bin:why3} prove -P z3 -t 30 toggle_toggle.why))))

