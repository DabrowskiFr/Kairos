(rule
 (alias runtest)
 (targets toggle_toggle.why)
 (deps toggle/toggle.obc)
 (action
  (progn
   (with-stdout-to %{target}
    (run %{bin:obc2why3} %{dep:toggle/toggle.obc}))
   (run why3 prove -P z3 -t 30 %{target}))))

