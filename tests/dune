(rule
 (alias runtest)
 (target golden_delay_int.gen.why)
 (deps delay/delay_int.obc)
 (action
  (with-stdout-to %{target}
   (run %{bin:obc2why3} delay/delay_int.obc))))

(rule
 (alias runtest)
 (deps golden/delay_int.why golden_delay_int.gen.why)
 (action
  (diff golden/delay_int.why golden_delay_int.gen.why)))

