node w_bundle_prev_window(open: int, close: int, x: int) returns (flag: int, out: int)
contracts
  requires: G((open = 0 or open = 1) and (close = 0 or close = 1));
  ensures: G (undefined_spec_symbol = 0);
locals
  hold: int;
states
  Init(init), Idle, Live;
invariants
  in Idle:
    flag = 0;
  in Live:
    flag = 1 and out = hold;
transitions
  Init:
    to Live when open = 1 and close = 0 {
      flag := 1;
      out := 0;
      hold := x;
    }
    to Idle when not (open = 1 and close = 0) {
      flag := 0;
      out := 0;
      hold := x;
    }
  Idle:
    to Live when open = 1 and close = 0 {
      flag := 1;
      out := 0;
      hold := x;
    }
    to Idle when not (open = 1 and close = 0) {
      flag := 0;
      out := 0;
      hold := x;
    }
  Live:
    to Idle when close = 1 {
      flag := 0;
      out := 0;
      hold := x;
    }
    to Live when close = 0 {
      flag := 1;
      out := hold;
      hold := x;
    }
end
