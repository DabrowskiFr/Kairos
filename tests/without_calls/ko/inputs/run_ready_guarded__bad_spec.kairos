node run_ready_guarded(go: int, err: int) returns (mode: int, ready: int)
contracts
  requires: G (err = 0 or err = 1);
  ensures: G (undefined_spec_symbol = 0);
locals
  armed: int;
states
  Init(init), Idle, Run;
invariants
  in Idle:
    mode = 0 and
    armed = 0;
  in Run:
    mode = armed and
    armed = 1;
transitions
  Init:
    to Run when go = 1 {
      armed := 1;
      mode := 1;
      if err = 0 then ready := 1;
      else ready := 0; end;
    }
    to Idle when go = 0 {
      armed := 0;
      mode := 0;
      ready := 0;
    }
  Idle:
    to Run when go = 1 {
      armed := 1;
      mode := 1;
      if err = 0 then ready := 1;
      else ready := 0; end;
    }
    to Idle when go = 0 {
      armed := 0;
      mode := 0;
      ready := 0;
    }
  Run:
    to Run {
      armed := 1;
      mode := 1;
      if err = 0 then ready := 1;
      else ready := 0; end;
    }
end
