(* BAD CODE — should be rejected by the verifier.
   Difference from ok/sticky_bypass_echo.kairos:
     Hold -> Hold sets  y := 0  instead of  y := latched.
   Why it must be rejected:
     The Hold-state invariant requires  y = latched.  Setting y := 0 violates
     this invariant in the self-loop.
     The contract  G(bypass=1 => X G(y = prev x))  is broken because y is 0
     instead of the latched value of x. *)
node sticky_bypass_echo(bypass: int, x: int) returns (y: int)
contracts
  ensures: G (bypass = 1 => X G (y = prev x));
locals
  latched: int;
states
  Init(init), Wait, Hold;
invariants
  in Hold:
    y = latched;
transitions
  Init:
    to Hold when bypass = 1 {
      y := x;
      latched := x;
    }
    to Wait when bypass = 0 {
      y := 0;
      latched := x;
    }
  Wait:
    to Hold when bypass = 1 {
      y := x;
      latched := x;
    }
    to Wait when bypass = 0 {
      y := 0;
      latched := x;
    }
  Hold:
    to Hold {
      y := 0; // BUG: should be  y := latched  (Hold invariant: y = latched)
      latched := latched;
    }
end
