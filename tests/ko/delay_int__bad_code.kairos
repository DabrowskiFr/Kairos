(* BAD CODE — should be rejected by the verifier.
   Difference from ok/delay_int.kairos:
     Run -> Run sets  y := 0  instead of  y := z.
   Why it must be rejected:
     The Run-state invariant guarantees  z = prev x.  The output y must be set
     to z to implement the one-cycle delay required by  X G(y = prev x).
     With y := 0 the output never reflects the previous input, so the contract
     fails as soon as x != 0. *)
node delay_int(x: int) returns (y: int)
contracts
  ensures: X ( G (y =  prev x) );
locals
  z : int;
states
  Init(init), Run;
invariants
  in Run:
    z = prev x;
transitions
  Init:
    to Run  {
    z := x;
  }
  Run:
    to Run  {
    y := 0; // BUG: should be  y := z  (z = prev x by Run invariant)
    z := x;
  }
end
