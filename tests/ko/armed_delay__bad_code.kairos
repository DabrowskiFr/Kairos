(* BAD CODE — should be rejected by the verifier.
   Difference from ok/armed_delay.kairos:
     Track -> Track sets  y := 0  instead of  y := z.
   Why it must be rejected:
     The Track-state invariant guarantees  z = prev x, i.e. z holds the delayed
     value of x.  The output y must be set to z to satisfy the contract
       G(arm = 1 => X G(y = prev x)).
     With y := 0, the output is always 0 regardless of x, so the contract fails
     as soon as x != 0 while armed. *)
node armed_delay(arm: int, x: int) returns (y: int)
contracts
  ensures: G (arm = 1 => X G (y = prev x));
locals
  z: int;
states
  Init(init), Idle, Track;
invariants
  in Track:
    z = prev x;
transitions
  Init:
    to Track when arm = 1 {
      y := 0;
      z := x;
    }
    to Idle when arm = 0 {
      y := 0;
      z := x;
    }
  Idle:
    to Track when arm = 1 {
      y := 0;
      z := x;
    }
    to Idle when arm = 0 {
      y := 0;
      z := x;
    }
  Track:
    to Track {
      y := 0; // BUG: should be  y := z  (z = prev x by Track invariant)
      z := x;
    }
end
