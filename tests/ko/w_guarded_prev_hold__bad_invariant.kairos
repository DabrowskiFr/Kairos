node w_guarded_prev_hold(gate: int, x: int) returns (y: int)
contracts
  requires: G(gate = 0 or gate = 1);
  ensures: next always ((gate = 1 and prev gate = 1) => ((y = 0) W (gate = 0)));
locals
  hold: int;
states
  Init(init), Wait, Hold;
invariants
  in Hold:
    0 = 1;
transitions
  Init:
    to Hold when gate = 1 {
      y := 0;
      hold := x;
    }
    to Wait when gate = 0 {
      y := 0;
      hold := x;
    }
  Wait:
    to Hold when gate = 1 {
      y := 0;
      hold := x;
    }
    to Wait when gate = 0 {
      y := 0;
      hold := x;
    }
  Hold:
    to Wait when gate = 0 {
      y := 0;
      hold := x;
    }
    to Hold when gate = 1 {
      y := 0;
      hold := x;
    }
end
