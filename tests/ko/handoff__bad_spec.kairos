node handoff() returns (modeA: int, modeB: int)
contracts
  ensures: G( {modeA} = {1} => X( {modeB} = {0} ) );
states
  Init(init), A, B;
invariants
  in A:
      modeA = 1;
      modeB = 0;
  in B:
      modeA = 0;
      modeB = 1;
transitions
  Init:
    to A {
      modeA := 1;
      modeB := 0;
    }
  A:
    to B  {
    modeA := 0;
    modeB := 1;
  }
  B:
    to A  {
    modeA := 1;
    modeB := 0;
  }
end
