node sticky_ack_plus(req: int) returns (ack: int)
contracts
  ensures: G (undefined_spec_symbol = 0);
states
  Init(init), Wait, Latched;
invariants
  in Wait:
    ack = 0;
  in Latched:
    ack = 1;
transitions
  Init:
    to Latched when req = 1 {
      ack := 1;
    }
    to Wait when req = 0 {
      ack := 0;
    }
  Wait:
    to Latched when req = 1 {
      ack := 1;
    }
    to Wait when req = 0 {
      ack := 0;
    }
  Latched:
    to Latched {
      ack := 1;
    }
end
