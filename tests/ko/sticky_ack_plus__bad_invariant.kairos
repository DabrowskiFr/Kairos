node sticky_ack_plus(req: int) returns (ack: int)
contracts
  ensures: G (req = 1 => G (ack = 1));
  ensures: G (ack = 1 => G (ack = 1));
states
  Init(init), Wait, Latched;
invariants
  in Init:
    undefined_invariant_symbol = 0;
transitions
  Init:
    to Latched when req = 1 {
      ack := 1;
    }
    to Wait when req = 0 {
      ack := 0;
    }
  Wait:
    to Latched when req = 1 {
      ack := 1;
    }
    to Wait when req = 0 {
      ack := 0;
    }
  Latched:
    to Latched {
      ack := 1;
    }
end
