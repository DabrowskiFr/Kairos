(* BAD CODE — should be rejected by the verifier.
   Differences from ok/guarded_delay_instance.kairos:
     Idle -> Run and Run -> Run both overwrite the instance result with  y := 0
     after the call to d.
   Why it must be rejected:
     Instance d returns the guarded delayed value into y.  Setting y := 0
     immediately after discards the result in every non-Init transition.
     The contract  G(enable=1 => X G(y = prev x))  is broken because y is
     always 0 instead of the delayed input. *)
import "./guarded_delay_core.kobj";

node guarded_delay_instance(enable: int, x: int) returns (y: int)
contracts
  ensures: G (enable = 1 => X G (y = prev x));
instances
  instance d: guarded_delay_core;
states
  Init(init), Idle, Run;
transitions
  Init:
    to Run when enable = 1 {
      call d(x) returns (y);
    }
    to Idle when enable = 0 {
      y := 0;
    }
  Idle:
    to Run when enable = 1 {
      call d(x) returns (y);
      y := 0; // BUG: overwrites instance result — should be removed
    }
    to Idle when enable = 0 {
      y := 0;
    }
  Run:
    to Run {
      call d(x) returns (y);
      y := 0; // BUG: overwrites instance result — should be removed
    }
end
