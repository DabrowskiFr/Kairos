node run_ready_guarded(go: int, err: int) returns (mode: int, ready: int)
contracts
  requires: G (err = 0 or err = 1);
  ensures: G (go = 1 => G (mode = 1));
  ensures: G (mode = 1 => G ((err = 0) => (ready = 1)));
  ensures: G (mode = 1 => G ((err = 1) => (ready = 0)));
locals
  armed: int;
states
  Init(init), Idle, Run;
invariants
  in Idle:
    undefined_invariant_symbol = 0;
  in Run:
    mode = armed and
    armed = 1;
transitions
  Init:
    to Run when go = 1 {
      armed := 1;
      mode := 1;
      if err = 0 then ready := 1;
      else ready := 0; end;
    }
    to Idle when go = 0 {
      armed := 0;
      mode := 0;
      ready := 0;
    }
  Idle:
    to Run when go = 1 {
      armed := 1;
      mode := 1;
      if err = 0 then ready := 1;
      else ready := 0; end;
    }
    to Idle when go = 0 {
      armed := 0;
      mode := 0;
      ready := 0;
    }
  Run:
    to Run {
      armed := 1;
      mode := 1;
      if err = 0 then ready := 1;
      else ready := 0; end;
    }
end
