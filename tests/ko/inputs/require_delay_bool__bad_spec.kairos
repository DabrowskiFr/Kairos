node require_delay_bool(u: int) returns (y: int)
contracts
  ensures: G ((y = y) and not (y = y));
  requires: G (u = 0 or u = 1);
locals
  m: int;
states
  Init(init), Run;
invariants
  in Run:
    m = prev u;
transitions
  Init:
    to Run {
      y := u;
      m := u;
    }
  Run:
    to Run {
      y := m;
      m := u;
    }
end
