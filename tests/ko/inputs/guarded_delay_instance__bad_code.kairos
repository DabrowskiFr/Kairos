node guarded_delay_core(x: int) returns (outv: int)
contracts
  ensures: X G (outv = prev x);
locals
  z: int;
states
  Init(init), Run;
invariants
  in Run:
    z = prev x;
transitions
  Init:
    to Run {
      outv := 0;
      z := x;
    }
  Run:
    to Run {
      outv := z;
      z := x;
    }
end

node guarded_delay_instance(enable: int, x: int) returns (y: int)
contracts
  ensures: G (enable = 1 => X G (y = prev x));
instances
  instance d: guarded_delay_core;
states
  Init(init), Idle, Run;
transitions
  Init:
    to Run when enable = 1 {
      call d(x) returns (y);
    }
    to Idle when enable = 0 {
      y := 0;
    }
  Idle:
    to Run when enable = 1 {
      call d(x) returns (y);
    }
    to Idle when enable = 0 {
      y := 0;
    }
  Run:
    to Run {
      y := undefined_code_symbol;
    }
end
