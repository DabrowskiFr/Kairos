node edge_rise(x: int) returns (y: int)
contracts
  ensures: G ((y = y) and not (y = y));
locals
  s : int;
states
  Init(init), Run;
invariants
  in Run:
    s = pre(x);
transitions
  Init:
    to Run  {
    y := 0;
    s := x;
  }
  Run:
    to Run  {
    if x = 1 and s = 0 then
      y := 1;
    else
      y := 0;
    end;
    s := x;
  }
end
