node w_mode_gate(start: int) returns (mode: int)
contracts
  ensures: G ((mode = mode) and not (mode = mode));
  requires: G(start = 0 or start = 1);
states
  Init(init), Run;
transitions
  Init:
    to Run {
      mode := 0;
    }
  Run:
    to Run when start = 0{
      skip;
    }
    to Run when start = 1{
      mode := 1;
    }
end
