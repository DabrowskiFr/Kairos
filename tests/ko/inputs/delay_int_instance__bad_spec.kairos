node delay_core(x: int) returns (outv: int)
contracts
  ensures: G ((outv = outv) and not (outv = outv));
locals
  z : int;
states
  Init(init), Run;
invariants
  in Run:
    z = prev x;
transitions
  Init:
    to Run {
    outv := 0;
    z := x;
  }
  Run:
    to Run {
    outv := z;
    z := x;
  }
end

node delay_int_instance(x: int) returns (y: int)
contracts
  ensures: G ((y = y) and not (y = y));
instances
  instance d: delay_core;
states
  Init(init), Run;
transitions
  Init:
    to Run {
    call d(x) returns (y);
  }
  Run:
    to Run {
    call d(x) returns (y);
  }
end
