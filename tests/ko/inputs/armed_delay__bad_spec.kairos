node armed_delay(arm: int, x: int) returns (y: int)
contracts
  ensures: G ((y = y) and not (y = y));
locals
  z: int;
states
  Init(init), Idle, Track;
invariants
  in Track:
    z = prev x;
transitions
  Init:
    to Track when arm = 1 {
      y := 0;
      z := x;
    }
    to Idle when arm = 0 {
      y := 0;
      z := x;
    }
  Idle:
    to Track when arm = 1 {
      y := 0;
      z := x;
    }
    to Idle when arm = 0 {
      y := 0;
      z := x;
    }
  Track:
    to Track {
      y := z;
      z := x;
    }
end
