node traffic3() returns (color: int)
contracts
  ensures: G (undefined_spec_symbol = 0);
locals
states
  Init(init), Green, Yellow, Red;
invariants
  in Green:
    color = 0;
  in Yellow:
    color = 1;
  in Red:
    color = 2;
transitions
  Init:
    to Green {
      color := 0;
    }
  Green:
    to Yellow  {
    color := 1;
  }
  Yellow:
    to Red  {
    color := 2;
  }
  Red:
    to Green  {
    color := 0;
  }
end
