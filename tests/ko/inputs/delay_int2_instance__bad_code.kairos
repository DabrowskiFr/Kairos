node delay_core(x: int) returns (outv: int)
contracts
  ensures: X ( G (outv = prev x) );
locals
  z : int;
states
  Init(init), Run;
invariants
  in Run:
    z = prev x;
transitions
  Init:
    to Run {
    outv := 0;
    z := x;
  }
  Run:
    to Run {
    outv := z;
    z := x;
  }
end

node delay_int2_instance(x: int) returns (y: int)
contracts
  ensures: next next always ( y = prev2 x );
instances
  instance d1: delay_core;
  instance d2: delay_core;
locals
  t : int;
states
  Init(init), Run;
transitions
  Init:
    to Run {
    call d1(x) returns (t);
    call d2(t) returns (y);
  }
  Run:
    to Run {
    y := undefined_code_symbol;
    call d2(t) returns (y);
  }
end
