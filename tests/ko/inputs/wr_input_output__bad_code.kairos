node wr_input_output(x: int) returns (y: int)
contracts
  requires: G(x = 0 or x = 1);
  ensures: X G((x = 1) => ((y = 1) W (x = 0)));
  ensures: X G((x = 1) R (y = 0 or x = 1));
states
  Init(init), Run;
transitions
  Init:
    to Run {
      y := x;
    }
  Run:
    to Run {
      y := 0;
    }
end
