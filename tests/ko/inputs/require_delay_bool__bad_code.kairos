node require_delay_bool(u: int) returns (y: int)
contracts
  requires: G (u = 0 or u = 1);
  ensures: next always (y = prev u);
locals
  m: int;
states
  Init(init), Run;
invariants
  in Run:
    m = prev u;
transitions
  Init:
    to Run {
      y := u;
      m := u;
    }
  Run:
    to Run {
      y := 0;
      m := u;
    }
end
