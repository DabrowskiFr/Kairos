import "./delay_core.kobj";

node delay_int2_instance(x: int) returns (y: int)
contracts
  ensures: next next always ( y = prev2 x );
instances
  instance d1: delay_core;
  instance d2: delay_core;
locals
  t : int;
states
  Init(init), Run;
invariants
  in Init:
    undefined_invariant_symbol = 0;
transitions
  Init:
    to Run {
    call d1(x) returns (t);
    call d2(t) returns (y);
  }
  Run:
    to Run {
    call d1(x) returns (t);
    call d2(t) returns (y);
  }
end
