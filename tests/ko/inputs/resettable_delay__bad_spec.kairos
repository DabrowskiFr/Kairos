node resettable_delay(reset: int, x: int) returns (y: int)
contracts
  requires : G ((reset = 0 or reset = 1) and (reset = 1 => x = 0));
  ensures: G (undefined_spec_symbol = 0);
locals
  m : int;
states
  Init(init), Run;
invariants
  in Run:
    (prev reset = 1 => m = 0) and
    (prev reset = 0 => m = prev x);
transitions
  Init:
    to Run when reset = 1 {
      y := 0;
      m := 0;
    }
    to Run when reset = 0 {
      y := 0;
      m := x;
    }
  Run:
    to Run when reset = 1 {
      y := 0;
      m := 0;
    }
    to Run when reset = 0 {
      y := m;
      m := x;
    }
end
  
