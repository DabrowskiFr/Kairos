import "./delay_int.kobj";

node delay_int_via_two_calls(x: int) returns (y: int)
contracts
  ensures: next next always (y = prev2 x);
instances
  instance d1: delay_int;
  instance d2: delay_int;
locals
  t : int;
states
  Init(init), Run;
transitions
  Init:
    to Run {
      call d1(x) returns (t);
      call d2(t) returns (y);
    }
  Run:
    to Run {
      call d1(x) returns (t);
      call d2(t) returns (y);
    }
end
