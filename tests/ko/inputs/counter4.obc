node counter4() returns (count: int)
guarantee G( {count} = {0} => X( {count} = {1} ) );
guarantee G( {count} = {1} => X( {count} = {2} ) );
guarantee G( {count} = {2} => X( {count} = {3} ) );
guarantee G( {count} = {3} => X( {count} = {0} ) );
locals
states
  S0(init), S1, S2, S3;
invariants
  in S0:
    count = 0;
  in S1:
    count = 1;
  in S2:
    count = 2;
  in S3:
    count = 3;
transitions
  S0:
    to S1  {
    count := 1;
  }
  S1:
    to S2  {
    count := 2;
  }
  S2:
    to S3  {
    count := 3;
  }
  S3:
    to S0  {
    count := 0;
  }
end
