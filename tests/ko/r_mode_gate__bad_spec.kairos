node w_mode_gate(start: int) returns (mode: int)
contracts
  requires: G(start = 0 or start = 1);
  ensures: (mode = 1) W (start = 1);
states
  Init(init), BeforeStart, AfterStart;
invariants
  in BeforeStart:
    mode = 0;
transitions
  Init:
    to BeforeStart {
      mode := 0;
    }
  BeforeStart:
    to BeforeStart when start = 0{
      skip;
    }
    to AfterStart when start = 1{
      mode := 1;
    }
  AfterStart:
    to AfterStart{
      skip;
    }
end
