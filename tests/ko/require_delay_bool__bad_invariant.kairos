node require_delay_bool(u: int) returns (y: int)
contracts
  requires: G (u = 0 or u = 1);
  ensures: next always (y = prev u);
locals
  m: int;
states
  Init(init), Run;
invariants
  in Run:
    0 = 1;
transitions
  Init:
    to Run {
      y := u;
      m := u;
    }
  Run:
    to Run {
      y := m;
      m := u;
    }
end
