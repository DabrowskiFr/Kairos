node counter4() returns (count: int)
guarantee G( {count} = {0} => X( {count} = {1} ) );
guarantee G( {count} = {1} => X( {count} = {2} ) );
guarantee G( {count} = {2} => X( {count} = {3} ) );
guarantee G( {count} = {3} => X( {count} = {0} ) );
guarantee G(G( {count} = {0} => X( {count} = {1} ) ));
locals
states
  S0, S1, S2, S3;
init S0
trans
  S0 -> S1 {
    requires {count} = {0};
    count := 1;
  }
  S1 -> S2 {
    requires {count} = {1};
    count := 2;
  }
  S2 -> S3 {
    requires {count} = {2};
    count := 3;
  }
  S3 -> S0 {
    requires {count} = {3};
    count := 0;
  }
end
