node light_latch(on: int, off: int) returns (light: int)
contracts
  requires: G((on = 0 or on = 1) and (off = 0 or off = 1));
  ensures: G(light = 0 or light = 1);
  ensures: X G(off = 1 => light = 0);
  ensures: X G((off = 0 and on = 1) => light = 1);
  ensures: X G((off = 0 and on = 0) => light = prev light);
states
  Init(init), Off, On;
invariants
  in Init:
    true;
  in Off:
    light = 0;
  in On:
    light = 1;
transitions
  Init:
    to Off {
      light := 0;
    }
  Off:
    to On when on = 1 and off = 0 {
      light := 1;
    }
    to Off when not (on = 1 and off = 0) {
      skip;
    }
  On:
    to Off when off = 1 {
      light := 0;
    }
    to On when off = 0 {
      skip;
    }
end
