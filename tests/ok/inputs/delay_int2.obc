node delay_int2(x: int) returns (y: int)
contracts
  guarantee X(X(G( y = pre_k(x, 2) )));
locals
  prev1, prev2: int;
states
  Init1(init), Init2, Run;
invariants
  in Init2:
    prev1 = pre_k(x, 1);
  in Run:
    prev1 = pre_k(x, 1);
    prev2 = pre_k(x,2);
trans
  Init1 -> Init2 {
    prev1 := x;
    prev2 := 0;
  }
  Init2 -> Run {
    prev2 := prev1;
    prev1 := x;
  }
  Run -> Run {
    y := prev2;
    prev2 := prev1;
    prev1 := x;
  }
end
