node delay_int2(x: int) returns (y: int)
guarantee X(X(G( {y} = pre_k(x, 2) )));
locals
  prev1: int;
  prev2: int;
states
  Init1, Init2, Run;
init Init1
trans
  Init1 -> Init2 {
    ensures {prev1} = {x};
    ensures {prev2} = {0};
    y := 0;
    prev1 := x;
    prev2 := 0;
  }
  Init2 -> Run {
    requires {prev1} = pre_k(x, 1);
    ensures {prev1} = {x};
    ensures {prev2} = pre_k(x, 1);
    y := 0;
    prev2 := prev1;
    prev1 := x;
  }
  Run -> Run {
    requires {prev1} = pre_k(x, 1);
    requires {prev2} = pre_k(x,2);
    ensures {prev1} = {x};
    ensures {prev2} = pre_k(x, 1);
    y := prev2;
    prev2 := prev1;
    prev1 := x;
  }
end
