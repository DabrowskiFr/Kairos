node debounce3() returns (stable: int)
guarantee G( {stable} = {1} => X( {stable} = {1} ) );
guarantee G(G( {stable} = {1} => X( {stable} = {1} ) ));
locals
states
  S0, S1, S2;
init S0
trans
  S0 -> S1 {
    requires {stable} = {0};
    stable := 0;
  }
  S1 -> S2 {
    requires {stable} = {0};
    stable := 1;
  }
  S2 -> S2 {
    requires {stable} = {1};
    stable := 1;
  }
end
