node edge_rise(x: int) returns (y: int)
contracts
  ensures:  G ( {y} = {1} => {x} = {1} );
  ensures: X G( {y} = {1} => pre(x) = {0} );
  ensures: X G( ({x} = {1} and pre(x) = {0}) => {y} = {1});
locals
  s : int;
states
  Init(init), Run;
invariants
  in Run:
    s = pre(x);
transitions
  Init:
    to Run  {
    y := 0;
    s := x;
  }
  Run:
    to Run  {
    if x = 1 and s = 0 then
      y := 1;
    else
      y := 0;
    end;
    s := x;
  }
end
