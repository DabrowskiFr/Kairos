node delay_int(x: int) returns (y: int)
guarantee X G( {y} = pre(x, 0) );
invariants
  (* none *)
locals
  prev: int;
states
  Init, Run;
init Init
trans
  Init -> Run {
    ensures {prev} = {x};
    y := 0;
    prev := x;
  }
  Run -> Run {
    requires {prev} = pre(x, 0);
    ensures {prev} = {x};
    y := prev;
    prev := x;
  }
end
