node light_latch_wr(on: int, off: int, lock: int) returns (light: int)
contracts
  requires: G((on = 0 or on = 1) and (off = 0 or off = 1) and (lock = 0 or lock = 1));
  ensures: G(light = 0 or light = 1);
  ensures: X G((on = 1 and off = 0 and lock = 0) => ((light = 1) W (off = 1 or lock = 1)));
  ensures: X G((lock = 1) => ((light = 0) W (lock = 0)));
  ensures: X G((off = 0 and lock = 0) R (light = 0));
states
  Init(init), Off, On, Locked;
invariants
  in Off:
    light = 0;
  in On:
    light = 1;
  in Locked:
    light = 0;
transitions
  Init:
    to Off {
      light := 0;
    }
  Off:
    to Locked when lock = 1 {
      light := 0;
    }
    to On when on = 1 and off = 0 and lock = 0 {
      light := 1;
    }
    to Off when lock = 0 and not (on = 1 and off = 0) {
      skip;
    }
  On:
    to Locked when lock = 1 {
      light := 0;
    }
    to Off when off = 1 {
      light := 0;
    }
    to On when off = 0 and lock = 0 {
      skip;
    }
  Locked:
    to Off when lock = 0 and off = 1 {
      light := 0;
    }
    to On when lock = 0 and on = 1 and off = 0 {
      light := 1;
    }
    to Locked when lock = 1 or (lock = 0 and not (on = 1 and off = 0) and off = 0) {
      light := 0;
    }
end
