{
  "name": "kairos-vscode",
  "displayName": "Kairos",
  "description": "Kairos language support via the Kairos LSP server",
  "version": "0.1.3",
  "publisher": "kairos",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:kairos",
    "onCommand:kairos.fetchOutline",
    "onCommand:kairos.run",
    "onCommand:kairos.build",
    "onCommand:kairos.prove",
    "onCommand:kairos.instrumentation",
    "onCommand:kairos.eval",
    "onCommand:kairos.cancelRun",
    "onCommand:kairos.resetState",
    "onCommand:kairos.automataPanel",
    "onCommand:kairos.dashboardPanel",
    "onCommand:kairos.explainFailure",
    "onCommand:kairos.artifactsPanel",
    "onCommand:kairos.evalPanel",
    "onCommand:kairos.pipelinePanel",
    "onCommand:kairos.compareAutomata",
    "onCommand:kairos.irPanel",
    "onCommand:kairos.exportHtmlReport",
    "onCommand:kairos.openRecentFile",
    "onCommand:kairos.diffObc",
    "onCommand:kairos.showRunHistory",
    "onCommand:kairos.openTraceLogs",
    "onCommand:kairos.openObc",
    "onCommand:kairos.openWhy",
    "onCommand:kairos.openVc",
    "onCommand:kairos.openSmt",
    "onCommand:kairos.openLabels",
    "onCommand:kairos.openAssumeText",
    "onCommand:kairos.openGuaranteeText",
    "onCommand:kairos.openProductText",
    "onCommand:kairos.openObligationsMap",
    "onCommand:kairos.openPruneReasons",
    "onView:kairosOutline",
    "onView:kairosGoals",
    "onView:kairosArtifacts",
    "onView:kairosRuns"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kairos.fetchOutline",
        "title": "Kairos: Fetch Outline (LSP)"
      },
      {
        "command": "kairos.openOutlineLocation",
        "title": "Kairos: Open Outline Location"
      },
      {
        "command": "kairos.openWhyForVc",
        "title": "Kairos: Open Why at VC"
      },
      {
        "command": "kairos.run",
        "title": "Kairos: Run (LSP)"
      },
      {
        "command": "kairos.build",
        "title": "Kairos: Build (Generate OBC/Why/VC)"
      },
      {
        "command": "kairos.prove",
        "title": "Kairos: Prove (Run VCs)"
      },
      {
        "command": "kairos.instrumentation",
        "title": "Kairos: Automata (Instrumentation Pass)"
      },
      {
        "command": "kairos.eval",
        "title": "Kairos: Eval Trace"
      },
      {
        "command": "kairos.cancelRun",
        "title": "Kairos: Cancel Run"
      },
      {
        "command": "kairos.resetState",
        "title": "Kairos: Reset State"
      },
      {
        "command": "kairos.automataPanel",
        "title": "Kairos: Open Automata Studio"
      },
      {
        "command": "kairos.dashboardPanel",
        "title": "Kairos: Open Proof Dashboard"
      },
      {
        "command": "kairos.explainFailure",
        "title": "Kairos: Open Explain Failure"
      },
      {
        "command": "kairos.artifactsPanel",
        "title": "Kairos: Open Artifacts Workspace"
      },
      {
        "command": "kairos.evalPanel",
        "title": "Kairos: Open Eval Playground"
      },
      {
        "command": "kairos.pipelinePanel",
        "title": "Kairos: Open Pipeline View"
      },
      {
        "command": "kairos.compareAutomata",
        "title": "Kairos: Compare Current and Previous Automata"
      },
      {
        "command": "kairos.irPanel",
        "title": "Kairos: Open IR Visualization"
      },
      {
        "command": "kairos.exportHtmlReport",
        "title": "Kairos: Export HTML Report"
      },
      {
        "command": "kairos.openRecentFile",
        "title": "Kairos: Open Recent File"
      },
      {
        "command": "kairos.diffObc",
        "title": "Kairos: Diff OBC with Previous Run"
      },
      {
        "command": "kairos.showRunHistory",
        "title": "Kairos: Show Run History"
      },
      {
        "command": "kairos.openTraceLogs",
        "title": "Kairos: Open Kairos Logs"
      },
      {
        "command": "kairos.openArtifact",
        "title": "Kairos: Open Artifact"
      },
      {
        "command": "kairos.openDumpPath",
        "title": "Kairos: Open SMT Dump"
      },
      {
        "command": "kairos.openObc",
        "title": "Kairos: Open OBC+"
      },
      {
        "command": "kairos.openWhy",
        "title": "Kairos: Open Why"
      },
      {
        "command": "kairos.openVc",
        "title": "Kairos: Open VC"
      },
      {
        "command": "kairos.openSmt",
        "title": "Kairos: Open SMT"
      },
      {
        "command": "kairos.openLabels",
        "title": "Kairos: Open Labels"
      },
      {
        "command": "kairos.openAssumeText",
        "title": "Kairos: Open Assume Automaton"
      },
      {
        "command": "kairos.openGuaranteeText",
        "title": "Kairos: Open Guarantee Automaton"
      },
      {
        "command": "kairos.openProductText",
        "title": "Kairos: Open Product Automaton"
      },
      {
        "command": "kairos.openObligationsMap",
        "title": "Kairos: Open Obligations Map"
      },
      {
        "command": "kairos.openPruneReasons",
        "title": "Kairos: Open Prune Reasons"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kairos",
          "title": "Kairos",
          "icon": "resources/kairos.svg"
        }
      ]
    },
    "views": {
      "kairos": [
        {
          "id": "kairosOutline",
          "name": "Outline"
        },
        {
          "id": "kairosGoals",
          "name": "Goals"
        },
        {
          "id": "kairosArtifacts",
          "name": "Artifacts"
        },
        {
          "id": "kairosRuns",
          "name": "Runs"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "kairos.evalPanel",
          "when": "resourceLangId == kairos",
          "group": "navigation"
        },
        {
          "command": "kairos.artifactsPanel",
          "when": "resourceLangId == kairos",
          "group": "navigation"
        },
        {
          "command": "kairos.openRecentFile",
          "when": "resourceLangId == kairos",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "kairos.openWhyForVc",
          "when": "view == kairosGoals && viewItem == kairosGoalVc"
        }
      ]
    },
    "keybindings": [
      {
        "command": "kairos.build",
        "key": "ctrl+alt+b",
        "mac": "cmd+alt+b",
        "when": "editorTextFocus && resourceLangId == kairos"
      },
      {
        "command": "kairos.prove",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p",
        "when": "editorTextFocus && resourceLangId == kairos"
      },
      {
        "command": "kairos.evalPanel",
        "key": "ctrl+alt+e",
        "mac": "cmd+alt+e",
        "when": "editorTextFocus && resourceLangId == kairos"
      },
      {
        "command": "kairos.cancelRun",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c",
        "when": "editorTextFocus && resourceLangId == kairos"
      }
    ],
    "languages": [
      {
        "id": "kairos",
        "aliases": [
          "Kairos",
          "kairos"
        ],
        "extensions": [
          ".kairos",
          ".obc"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "kir",
        "aliases": [
          "Kairos IR",
          "kir"
        ],
        "extensions": [
          ".kir"
        ]
      }
    ],
    "grammars": [
      {
        "language": "kairos",
        "scopeName": "source.kairos",
        "path": "./syntaxes/kairos.tmLanguage.json"
      },
      {
        "language": "kir",
        "scopeName": "source.kir",
        "path": "./syntaxes/kir.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Kairos",
      "properties": {
        "kairos.lsp.serverPath": {
          "type": "string",
          "default": "kairos-lsp",
          "description": "Path to the Kairos LSP server executable."
        },
        "kairos.lsp.serverArgs": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Extra arguments for the Kairos LSP server."
        },
        "kairos.lsp.trace": {
          "type": "boolean",
          "default": false,
          "description": "Enable LSP server tracing (KAIROS_LSP_TRACE=1)."
        },
        "kairos.lsp.traceFile": {
          "type": "string",
          "default": "",
          "description": "Trace log file path (KAIROS_LSP_TRACE_FILE)."
        },
        "kairos.run.engine": {
          "type": "string",
          "default": "v2",
          "enum": [
            "v2"
          ],
          "description": "Kairos engine to use for runs."
        },
        "kairos.run.prover": {
          "type": "string",
          "default": "z3",
          "description": "Default prover used for Build and Prove."
        },
        "kairos.run.proverCmd": {
          "type": "string",
          "default": "",
          "description": "Optional explicit prover command."
        },
        "kairos.run.timeoutS": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "description": "Prover timeout in seconds."
        },
        "kairos.run.wpOnly": {
          "type": "boolean",
          "default": false,
          "description": "Generate weakest-precondition obligations only."
        },
        "kairos.run.smokeTests": {
          "type": "boolean",
          "default": false,
          "description": "Enable smoke obligations during prove runs."
        },
        "kairos.run.prefixFields": {
          "type": "boolean",
          "default": false,
          "description": "Prefix fields during Why generation."
        },
        "kairos.run.generateVcText": {
          "type": "boolean",
          "default": true,
          "description": "Keep VC text in run outputs."
        },
        "kairos.run.generateSmtText": {
          "type": "boolean",
          "default": true,
          "description": "Keep SMT text in run outputs."
        },
        "kairos.run.generateMonitorText": {
          "type": "boolean",
          "default": true,
          "description": "Keep automata and product textual outputs in run outputs."
        },
        "kairos.run.generateDotPng": {
          "type": "boolean",
          "default": false,
          "description": "Request PNG generation from the backend during runs."
        },
        "kairos.ui.openDashboardAfterProve": {
          "type": "boolean",
          "default": true,
          "description": "Open the proof dashboard automatically after a prove run."
        },
        "kairos.ui.restoreSession": {
          "type": "boolean",
          "default": true,
          "description": "Refresh outline and restore Kairos context when reopening the workspace."
        },
        "kairos.ui.exportReportOnDemand": {
          "type": "boolean",
          "default": true,
          "description": "Enable HTML proof report export commands."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "prepublishOnly": "npm run compile"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.3.3"
  }
}
